# ──────────────────────────────────────────────────────────────────────────
# Foundry-Hub — SERVER (NestJS) environment
# Copy to `.env`:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (the client app)
CORS_ORIGINS=http://localhost:3000

# ---- Database (Postgres) ----
# For LOCAL dev against `docker compose -f docker-compose.dev.yml up`, use
# localhost + the mapped port 5434. Inside the full `docker compose up` stack
# these are overridden to postgres:5432 automatically.
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USER=foundry
DATABASE_PASSWORD=foundry_secret
DATABASE_NAME=foundry_hub
# Auto-create/update tables from entities (great for MVP/dev; disable for prod migrations)
DB_SYNC=true
DB_LOGGING=false

# ---- Redis (BullMQ queue + cache + rate limiting) ----
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ---- Auth / JWT ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Password reset token lifetime (seconds)
RESET_TOKEN_TTL=3600

# ---- Seed a demo designer + client on first boot ----
SEED_ON_BOOT=true

# ---- DigitalOcean Spaces (S3-compatible object storage) ----
# Leave blank to disable uploads in dev (upload endpoints return 503).
# DigitalOcean Spaces Configuration
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
DO_SPACES_REGION=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=

# ---- Product import worker ----
IMPORT_TIMEOUT_MS=10000
IMPORT_USER_AGENT=FoundryHubBot/1.0 (+https://foundry-hub.dev)

# ---- Email (Resend). Leave RESEND_API_KEY blank to log emails to console ----
RESEND_API_KEY=
# Must be a verified sender/domain in Resend, e.g. "Foundry Hub <no-reply@yourdomain.com>"
EMAIL_FROM=
APP_NAME=Foundry Hub

# ---- Rate limiting ----
THROTTLE_TTL=60
THROTTLE_LIMIT=120



